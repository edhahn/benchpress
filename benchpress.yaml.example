providers:
  # Anthropic direct
  - name: "anthropic"
    base_url: "https://api.anthropic.com/v1"
    api_key_env: "ANTHROPIC_API_KEY"
    insights_context: "Direct connection to Anthropic's API with no middleware."
    # extra_headers:                        # optional provider-level headers
    #   X-Custom-Header: "value"
    models:
      - id: "claude-opus-4-6"
        display_name: "Opus 4.6"
        base_model: "claude-opus-4-6"       # groups same model across providers
        # extra_headers:                    # optional per-model headers
        #   anthropic-beta: "interleaved-thinking-2025-05-14"
        cost_per_1k_input: 0.015
        cost_per_1k_output: 0.075
      - id: "claude-opus-4-5"
        display_name: "Opus 4.5"
        base_model: "claude-opus-4-5"
        cost_per_1k_input: 0.015
        cost_per_1k_output: 0.075
      - id: "claude-sonnet-4-6"
        display_name: "Sonnet 4.6"
        base_model: "claude-sonnet-4-6"
        cost_per_1k_input: 0.003
        cost_per_1k_output: 0.015
      - id: "claude-sonnet-4-5"
        display_name: "Sonnet 4.5"
        base_model: "claude-sonnet-4-5"
        cost_per_1k_input: 0.003
        cost_per_1k_output: 0.015
      - id: "claude-haiku-4-5"
        display_name: "Haiku 4.5"
        base_model: "claude-haiku-4-5"
        cost_per_1k_input: 0.0008
        cost_per_1k_output: 0.004

  # OAuth client_credentials provider (e.g., Gloo AI)
  # Uses OAuth2 token exchange instead of a static API key.
  # auth_method: "basic" sends credentials via HTTP Basic auth header.
  # auth_method: "post_body" sends credentials as form fields.
  # - name: "gloo-ai"
  #   base_url: "https://platform.ai.gloo.com/ai/v2/"
  #   oauth:
  #     token_url: "https://platform.ai.gloo.com/oauth2/token"
  #     client_id_env: "GLOO_AI_CLIENT_ID"
  #     client_secret_env: "GLOO_AI_CLIENT_SECRET"
  #     scopes: ["api/access"]
  #     auth_method: "basic"
  #   insights_context: |
  #     Gloo AI provides faith-based guardrails and prompt enhancements
  #     for the faith ecosystem. Acknowledge the value these safety
  #     features add beyond raw performance numbers.
  #   models:
  #     - id: "gloo-anthropic-claude-sonnet-4.5"
  #       display_name: "Gloo AI - Sonnet 4.5"
  #       base_model: "claude-sonnet-4-5"
  #       cost_per_1k_input: 0.00321
  #       cost_per_1k_output: 0.01646

  # OpenAI direct
  # - name: "openai"
  #   base_url: "https://api.openai.com/v1"
  #   api_key_env: "OPENAI_API_KEY"
  #   models:
  #     - id: "gpt-4.1"
  #       display_name: "GPT-4.1"
  #       cost_per_1k_input: 0.002
  #       cost_per_1k_output: 0.008

  # OpenRouter (access 200+ models via a single API key)
  # Uses OpenAI-compatible format. Model IDs use vendor/model syntax.
  # - name: "openrouter"
  #   base_url: "https://openrouter.ai/api/v1"
  #   api_key_env: "OPENROUTER_API_KEY"
  #   extra_headers:
  #     HTTP-Referer: "https://github.com/benchpress"
  #     X-Title: "Benchpress"
  #   models:
  #     - id: "anthropic/claude-sonnet-4.5"
  #       display_name: "OR - Sonnet 4.5"
  #       base_model: "claude-sonnet-4-5"
  #       cost_per_1k_input: 0.003
  #       cost_per_1k_output: 0.015
  #     - id: "xiaomi/mimo-v2-pro"
  #       display_name: "Mimo-V2-Pro"
  #       cost_per_1k_input: 0
  #       cost_per_1k_output: 0

  # Local Ollama
  # - name: "ollama"
  #   base_url: "http://localhost:11434/v1"
  #   models:
  #     - id: "llama3.3:70b"
  #       display_name: "Llama 3.3 70B"
  #       cost_per_1k_input: 0.0
  #       cost_per_1k_output: 0.0

test:
  num_requests: 20
  concurrency: 3
  interval_ms: 500
  timeout_s: 120
  max_tokens: 1024
  temperature: 0.0
  seed: 42

report:
  results_dir: "./results"
  report_path: "./reports"

  # LLM for generating report insights (optional).
  # Option A: reference an existing provider by name
  llm_provider: "anthropic"
  llm_model: "claude-sonnet-4-5"

  # Option B: standalone LLM config (mutually exclusive with llm_provider/llm_model)
  # llm:
  #   base_url: "https://api.anthropic.com/v1"
  #   api_key_env: "ANTHROPIC_API_KEY"
  #   model: "claude-sonnet-4-5"
  #   # Also supports oauth block:
  #   # oauth:
  #   #   token_url: "https://example.com/oauth2/token"
  #   #   client_id_env: "CLIENT_ID"
  #   #   client_secret_env: "CLIENT_SECRET"
  #   #   scopes: ["api/access"]
  #   #   auth_method: "basic"
